{
  "resourceType": "StructureDefinition",
  "id": "cied-diagnostic-report",
  "url": "http://hl7.org/fhir/uv/cardx-cied/StructureDefinition/cied-diagnostic-report",
  "name": "CIEDDiagnosticReport",
  "title": "CIED Diagnostic Report Profile",
  "status": "active",
  "description": "\nThe CIED Diagnostic Report Profile contains the metadata, device references,observation references, and attachments for an interrogated device transmission. Several device\nand observation references may exist depending on the number of devices implanted in a patient and how the observation data are associated with the devices. Separate observations may\nalso be created during additional post-processing by the remote monitoring software or other processing systems used to interrogate the device data.\n",
  "fhirVersion": "5.0.0",
  "kind": "resource",
  "abstract": false,
  "type": "DiagnosticReport",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/DiagnosticReport",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "DiagnosticReport.status",
        "path": "DiagnosticReport.status",
        "mustSupport": true
      },
      {
        "id": "DiagnosticReport.code",
        "path": "DiagnosticReport.code",
        "mustSupport": true
      },
      {
        "id": "DiagnosticReport.subject",
        "path": "DiagnosticReport.subject",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/uv/cardx-cied/StructureDefinition/cied-patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "DiagnosticReport.effective[x]",
        "path": "DiagnosticReport.effective[x]",
        "slicing": {
          "discriminator": [
            {
              "type": "type",
              "path": "$this"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "DiagnosticReport.effective[x]:effectiveDateTime",
        "path": "DiagnosticReport.effective[x]",
        "sliceName": "effectiveDateTime",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "dateTime"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "DiagnosticReport.result",
        "path": "DiagnosticReport.result",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/uv/cardx-cied/StructureDefinition/IdcoObservation"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "DiagnosticReport.presentedForm",
        "path": "DiagnosticReport.presentedForm",
        "mustSupport": true
      }
    ]
  }
}
